{
  "name": "@mindflow/openclaw",
  "version": "0.1.0",
  "description": "MindFlow — personal knowledge graph plugin for OpenClaw",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "openclaw": {
