    "skills": ["./skills/mindflow-setup"],
    "hooks": ["./hooks/mindflow-ingest"]
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0"
  },
  "optionalDependencies": {
    "@anthropic-ai/sdk": "^0.80.0"
  },
  "files": [
    "dist/",
    "skills/",
    "hooks/",
    "openclaw.plugin.json"
  ]
}
